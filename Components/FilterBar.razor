@rendermode InteractiveServer

<div class="flex gap-2" role="group" aria-label="Filter groceries">
    @foreach (var filter in Filters)
    {
        <button class="rounded-md border px-3 py-1.5 text-sm font-medium transition @(filter == ActiveFilter ? "border-slate-900 bg-slate-900 text-white" : "border-slate-300 text-slate-700 hover:bg-slate-100")"
                @onclick="() => OnFilterChanged.InvokeAsync(filter)"
                aria-pressed="@(filter == ActiveFilter)">
            @filter
        </button>
    }
</div>

@code {
    [Parameter, EditorRequired]
    public string ActiveFilter { get; set; } = "All";

    [Parameter, EditorRequired]
    public EventCallback<string> OnFilterChanged { get; set; }

    private static readonly string[] Filters = ["All", "Needed", "Purchased"];
}
