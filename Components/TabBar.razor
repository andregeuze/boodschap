@rendermode InteractiveServer

<div class="flex gap-2" role="group" aria-label="@AriaLabel">
	@foreach (var tab in Tabs)
	{
		<button class="rounded-md border px-3 py-1.5 text-sm font-medium transition @(tab == ActiveTab ? "border-slate-900 bg-slate-900 text-white" : "border-slate-300 text-slate-700 hover:bg-slate-100")"
				@onclick="() => OnTabChanged.InvokeAsync(tab)"
				aria-pressed="@(tab == ActiveTab)">
			@tab
		</button>
	}
</div>

@code {
	[Parameter, EditorRequired]
	public IReadOnlyList<string> Tabs { get; set; } = [];

	[Parameter, EditorRequired]
	public string ActiveTab { get; set; } = string.Empty;

	[Parameter, EditorRequired]
	public EventCallback<string> OnTabChanged { get; set; }

	[Parameter]
	public string AriaLabel { get; set; } = "Tabs";
}