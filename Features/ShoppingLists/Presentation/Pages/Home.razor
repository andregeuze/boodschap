@page "/"
@rendermode InteractiveServer
@implements IDisposable
@inject NavigationManager Navigation
@inject IShoppingListService ShoppingLists
@inject StoreChangeNotifier StoreChangeNotifier

<PageTitle>Boodschap</PageTitle>

<div class="min-h-screen bg-slate-50">
	<section class="mx-auto flex w-full max-w-4xl flex-col gap-6 px-4 py-8">
		<div class="flex flex-col gap-4 rounded-3xl border border-slate-200 bg-white p-6 shadow-sm sm:flex-row sm:items-end sm:justify-between">
			<div class="space-y-2">
				<p class="text-sm font-medium uppercase tracking-[0.2em] text-slate-500">Shopping lists</p>
				<h1 class="text-3xl font-semibold tracking-tight text-slate-900">Pick a list and keep moving.</h1>
				<p class="max-w-2xl text-sm text-slate-600">Your active lists stay front and center, while archived lists remain easy to revisit.</p>
			</div>

			<button class="rounded-md bg-slate-900 px-4 py-2 text-sm font-medium text-white transition hover:bg-slate-700"
					@onclick="CreateList">
				New list
			</button>
		</div>

		<div class="space-y-4">
			<TabBar Tabs="Tabs"
					ActiveTab="@activeTab"
					OnTabChanged="SelectTab"
					AriaLabel="Shopping list status" />

			@if (VisibleLists.Count == 0)
			{
				<div class="rounded-2xl border border-dashed border-slate-300 bg-white px-6 py-10 text-center text-sm text-slate-500">
					No lists in this view yet.
				</div>
			}
			else
			{
				<div class="grid gap-3">
					@foreach (var list in VisibleLists)
					{
						<div class="flex flex-col gap-3 sm:flex-row sm:items-stretch">
							<button class="w-full rounded-2xl border border-slate-200 bg-white p-5 text-left shadow-sm transition hover:-translate-y-0.5 hover:border-slate-300 hover:shadow-md sm:flex-1"
									@onclick="() => OpenList(list.Id)">
								<div class="flex items-start justify-between gap-4">
									<div class="space-y-1">
										<h2 class="text-lg font-semibold text-slate-900">@list.Name</h2>
										<p class="text-sm text-slate-600">@list.Description</p>
									</div>
									<span class="rounded-full bg-slate-100 px-3 py-1 text-xs font-medium text-slate-600">@GetSummary(list)</span>
								</div>
							</button>

							@if (list.Archived)
							{
								<button class="rounded-2xl border border-rose-200 bg-rose-50 px-4 py-3 text-sm font-medium text-rose-700 transition hover:border-rose-300 hover:bg-rose-100 sm:self-stretch"
										@onclick="() => RemoveArchivedList(list.Id)">
									Remove
								</button>
							}
						</div>
					}
				</div>
			}
		</div>
	</section>
</div>

@code {
	private const string NewTab = "New";
	private const string ArchivedTab = "Archived";

	private static readonly string[] Tabs = [NewTab, ArchivedTab];

	[SupplyParameterFromQuery(Name = "tab")]
	public string? RequestedTab { get; set; }

	private string activeTab = NewTab;
	private List<ShoppingList> shoppingLists = [];

	private List<ShoppingList> VisibleLists => shoppingLists
		.Where(list => activeTab == ArchivedTab ? list.Archived : !list.Archived)
		.ToList();

	protected override async Task OnInitializedAsync()
	{
		StoreChangeNotifier.Changed += HandleStoreChangedAsync;
		shoppingLists = [.. await ShoppingLists.GetListsAsync()];
	}

	protected override void OnParametersSet()
	{
		activeTab = RequestedTab == ArchivedTab ? ArchivedTab : NewTab;
	}

	public void Dispose()
	{
		StoreChangeNotifier.Changed -= HandleStoreChangedAsync;
	}

	private void SelectTab(string tab)
	{
		activeTab = tab;
	}

	private void OpenList(int id)
	{
		Navigation.NavigateTo($"/lists/{id}");
	}

	private async Task CreateList()
	{
		var list = await ShoppingLists.CreateListAsync($"Shopping list {DateTime.Now:HHmm}");
		Navigation.NavigateTo($"/lists/{list.Id}");
	}

	private async Task RemoveArchivedList(int id)
	{
		if (!await ShoppingLists.RemoveArchivedListAsync(id))
		{
			return;
		}

		shoppingLists.RemoveAll(list => list.Id == id);
	}

	private Task HandleStoreChangedAsync(StoreChange _)
	{
		return InvokeAsync(async () =>
		{
			shoppingLists = [.. await ShoppingLists.GetListsAsync()];
			StateHasChanged();
		});
	}

	private static string GetSummary(ShoppingList list)
	{
		var purchasedCount = list.Items.Count(item => item.IsDone);
		return $"{purchasedCount}/{list.Items.Count} purchased";
	}
}