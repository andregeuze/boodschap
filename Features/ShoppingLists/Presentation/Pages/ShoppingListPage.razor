@page "/lists/{Id:int}"
@rendermode InteractiveServer
@implements IDisposable
@inject NavigationManager Navigation
@inject IShoppingListService ShoppingLists
@inject StoreChangeNotifier StoreChangeNotifier

@if (shoppingList is null)
{
	<PageTitle>List not found</PageTitle>

	<div class="mx-auto flex min-h-screen w-full max-w-3xl flex-col items-center justify-center gap-4 px-4 text-center">
		<h1 class="text-2xl font-semibold text-slate-900">Shopping list not found</h1>
		<p class="text-sm text-slate-600">The selected list does not exist.</p>
		<button class="rounded-md bg-slate-900 px-4 py-2 text-sm font-medium text-white hover:bg-slate-700"
				@onclick="BackToOverview">
			Back to overview
		</button>
	</div>
}
else
{
	<PageTitle>@shoppingList.Name</PageTitle>

	<div class="min-h-screen">
		<header class="sticky top-0 z-20 border-b border-slate-200 bg-white/95 backdrop-blur">
			<div class="mx-auto flex w-full max-w-3xl items-center justify-between gap-3 px-4 py-3">
				<div class="flex items-center gap-3">
					<button class="rounded-md border border-slate-300 px-3 py-2 text-sm font-medium text-slate-700 transition hover:bg-slate-100"
							@onclick="BackToOverview">
						Back
					</button>

					<div>
						<p class="text-xs uppercase tracking-[0.2em] text-slate-500">Shopping list</p>
						<h1 class="text-lg font-semibold text-slate-900">@shoppingList.Name</h1>
					</div>
				</div>

				<div class="flex items-center gap-2">
					@if (shoppingList.Archived)
					{
						<span class="rounded-full bg-slate-100 px-3 py-2 text-xs font-medium uppercase tracking-[0.2em] text-slate-500">Archived</span>
						<button class="rounded-md border border-slate-300 px-3 py-2 text-sm font-medium text-slate-700 transition hover:bg-slate-100"
								@onclick="UnarchiveList">
							Unarchive
						</button>
					}
					else
					{
						<button class="rounded-md border border-slate-300 px-3 py-2 text-sm font-medium text-slate-700 transition hover:bg-slate-100"
								@onclick="ArchiveList">
							Archive
						</button>
					}

					<button class="rounded-md bg-slate-900 px-3 py-2 text-sm font-medium text-white transition hover:bg-slate-700"
							@onclick="ToggleQuickAdd">
						New item
					</button>
				</div>
			</div>

			@if (isQuickAddOpen)
			{
				<div class="mx-auto w-full max-w-3xl px-4 pb-3">
					<form class="flex gap-2" @onsubmit="AddItem">
						<input class="w-full rounded-md border border-slate-300 px-3 py-2 text-sm outline-none ring-slate-300 placeholder:text-slate-400 focus:ring-2"
							   placeholder="Add grocery item"
							   @bind="newItemName"
							   @bind:event="oninput"
							   autofocus />
						<button type="submit" class="rounded-md bg-slate-900 px-3 py-2 text-sm font-medium text-white hover:bg-slate-700">Add</button>
					</form>
				</div>
			}
		</header>

		<section class="mx-auto w-full max-w-3xl px-4 py-6">
			<div class="mb-3 flex items-center justify-between">
				<div>
					<h2 class="text-xl font-semibold">Groceries</h2>
					@if (!string.IsNullOrWhiteSpace(shoppingList.Description))
					{
						<p class="text-sm text-slate-500">@shoppingList.Description</p>
					}
				</div>

				@if (selectedFilter == ShoppingItemFilters.All)
				{
					<p class="text-sm text-slate-500">Drag to reorder</p>
				}
			</div>

			<div class="mb-4">
				<FilterBar ActiveFilter="@selectedFilter" OnFilterChanged="SelectFilter" />
			</div>

			<ul class="space-y-2">
				@foreach (var item in VisibleItems)
				{
					<li class="flex items-center justify-between rounded-md border px-3 py-3 shadow-sm transition-all duration-150 @(dragOverItem == item ? "border-slate-400 bg-slate-50 ring-2 ring-slate-300" : "border-slate-200 bg-white") @(dragItem == item ? "opacity-50" : "")"
						draggable="true"
						@ondragstart="() => HandleDragStart(item)"
						@ondragend="HandleDragEnd"
						@ondragenter="() => HandleDragEnter(item)"
						@ondragover:preventDefault
						@ondrop="() => HandleDrop(item)"
						@key="item.Id">
						<label class="flex items-center gap-3">
							<input type="checkbox" checked="@item.IsDone" @onchange="(args) => ToggleDone(item.Id, args.Value)" class="h-4 w-4 accent-slate-900" />
							<span class="text-sm @(item.IsDone ? "line-through text-slate-400" : "text-slate-800")">@item.Name</span>
						</label>
						<button class="rounded-md px-2 py-1 text-xs text-slate-400 hover:bg-slate-100 hover:text-slate-700"
								@onclick="() => RemoveItem(item.Id)">
							Remove
						</button>
					</li>
				}
			</ul>
		</section>
	</div>
}

@code {
	[Parameter]
	public int Id { get; set; }

	private ShoppingList? shoppingList;
	private ShoppingListItem? dragItem;
	private ShoppingListItem? dragOverItem;
	private bool isQuickAddOpen;
	private string selectedFilter = ShoppingItemFilters.All;
	private string newItemName = string.Empty;

	private List<ShoppingListItem> VisibleItems => selectedFilter switch
	{
		ShoppingItemFilters.Needed => shoppingList?.Items.Where(item => !item.IsDone).ToList() ?? [],
		ShoppingItemFilters.Purchased => shoppingList?.Items.Where(item => item.IsDone).ToList() ?? [],
		_ => shoppingList?.Items ?? []
	};

	protected override void OnInitialized()
	{
		StoreChangeNotifier.Changed += HandleStoreChangedAsync;
	}

	protected override async Task OnParametersSetAsync()
	{
		shoppingList = await ShoppingLists.GetListAsync(Id);
	}

	public void Dispose()
	{
		StoreChangeNotifier.Changed -= HandleStoreChangedAsync;
	}

	private void BackToOverview()
	{
		Navigation.NavigateTo(shoppingList?.Archived is true ? "/?tab=Archived" : "/");
	}

	private async Task ArchiveList()
	{
		if (shoppingList is null || shoppingList.Archived)
		{
			return;
		}

		shoppingList = await ShoppingLists.ArchiveListAsync(Id) ?? shoppingList;
		Navigation.NavigateTo("/?tab=Archived");
	}

	private async Task UnarchiveList()
	{
		if (shoppingList is null || !shoppingList.Archived)
		{
			return;
		}

		shoppingList = await ShoppingLists.UnarchiveListAsync(Id) ?? shoppingList;
	}

	private void ToggleQuickAdd()
	{
		isQuickAddOpen = !isQuickAddOpen;
	}

	private void SelectFilter(string filter)
	{
		selectedFilter = filter;
	}

	private async Task AddItem()
	{
		if (shoppingList is null || string.IsNullOrWhiteSpace(newItemName))
		{
			return;
		}

		shoppingList = await ShoppingLists.AddItemAsync(Id, newItemName);
		newItemName = string.Empty;
		selectedFilter = ShoppingItemFilters.All;
	}

	private async Task ToggleDone(int id, object? value)
	{
		if (shoppingList is null)
		{
			return;
		}

		var isDone = value is bool done && done;
		shoppingList = await ShoppingLists.ToggleDoneAsync(Id, id, isDone) ?? shoppingList;
	}

	private async Task RemoveItem(int id)
	{
		if (shoppingList is null)
		{
			return;
		}

		shoppingList = await ShoppingLists.RemoveItemAsync(Id, id) ?? shoppingList;
	}

	private void HandleDragStart(ShoppingListItem item) => dragItem = item;

	private void HandleDragEnd()
	{
		dragItem = null;
		dragOverItem = null;
	}

	private void HandleDragEnter(ShoppingListItem item) => dragOverItem = item;

	private async Task HandleDrop(ShoppingListItem target)
	{
		if (shoppingList is null || dragItem is null || dragItem == target || selectedFilter != ShoppingItemFilters.All)
		{
			return;
		}

		shoppingList = await ShoppingLists.ReorderItemAsync(Id, dragItem.Id, target.Id) ?? shoppingList;
		HandleDragEnd();
	}

	private Task HandleStoreChangedAsync(StoreChange change)
	{
		if (change.ListId is int listId && listId != Id)
		{
			return Task.CompletedTask;
		}

		return InvokeAsync(async () =>
		{
			shoppingList = await ShoppingLists.GetListAsync(Id);
			StateHasChanged();
		});
	}
}